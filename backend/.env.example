# ═══════════════════════════════════════════════════════════════════════════════
# AuraGraph — Environment Configuration
# Team Wowffulls | IIT Roorkee | AI Study Buddy Challenge
#
# Copy to .env and fill in your Azure resource values.
# Required variables are marked  ← REQUIRED
# Optional (have fallbacks) are   ← OPTIONAL
# ═══════════════════════════════════════════════════════════════════════════════

# ── Azure OpenAI  ← REQUIRED for AI note generation ──────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure OpenAI text-embedding-3-large  ← OPTIONAL (local TF-IDF fallback if blank)
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ── Azure AI Vision  ← OPTIONAL (Groq vision fallback if blank) ───────────────
# Used for: slide image OCR, figure captioning, diagram understanding.
# Azure Portal → AI Services → Computer Vision → Keys and Endpoint
AZURE_VISION_ENDPOINT=https://your-vision.cognitiveservices.azure.com/
AZURE_VISION_KEY=your-vision-key

# ── Azure AI Content Safety  ← OPTIONAL (pass-through if blank) ───────────────
# Used for: screening all LLM-generated text before it reaches the student.
# Azure Portal → AI Services → Content Safety → Keys and Endpoint
AZURE_CONTENT_SAFETY_ENDPOINT=https://your-content-safety.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_KEY=your-content-safety-key

# ── Azure AI Search  ← OPTIONAL (numpy in-memory fallback if blank) ───────────
# Used for: persistent vector RAG — stores & retrieves textbook+slide embeddings.
# Azure Portal → AI Search → Overview → Url  |  Keys → Admin key
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your-search-admin-key
AZURE_SEARCH_INDEX=auragraph-chunks

# ── Azure Cosmos DB  ← OPTIONAL (SQLite fallback if blank) ────────────────────
# Used for: persistent Cognitive Knowledge Graph (concept nodes + mastery edges).
# Azure Portal → Cosmos DB → Keys → PRIMARY CONNECTION STRING
COSMOS_DB_URL=https://your-cosmos.documents.azure.com:443/
COSMOS_DB_KEY=your-cosmos-primary-key
COSMOS_DB_DATABASE=auragraph
COSMOS_DB_CONTAINER=mastery
COSMOS_DB_BEHAVIOUR_CONTAINER=behaviour    # Behaviour tracking container

# ── Media ingestion (optional) ────────────────────────────────────────────────
AZURE_WHISPER_DEPLOYMENT=whisper              # Azure OpenAI Whisper deployment name    # Behaviour tracking container

# ── Groq  ← OPTIONAL (used as LLM fallback + vision when Azure unavailable) ───
GROQ_API_KEY=gsk_your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Security ───────────────────────────────────────────────────────────────────
# NEVER set DEMO_ENABLED=true in production. Allows password-free demo login.
DEMO_ENABLED=false
TOKEN_PEPPER=change-this-to-a-long-random-secret-in-production

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Pipeline limits ────────────────────────────────────────────────────────────
# These are deliberately unlimited for single-user / dev mode.
# Set to lower values only if sharing the backend with many simultaneous users.
MAX_TOTAL_UPLOAD_MB=2000
MAX_KS_MB=200
PIPELINE_TIMEOUT_S=86400
LLM_HOURLY_LIMIT=99999
LLM_DAILY_LIMIT=99999
LLM_CONCURRENCY=20

# ── Feedback & Admin ─────────────────────────────────────────────────────────
# Discord/Slack webhook — student feedback is posted here instantly
FEEDBACK_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# Admin key — protects GET /api/feedback endpoint (use any strong random string)
ADMIN_KEY=your-secret-admin-key

# ── Azure Cognitive Services Speech  ← REQUIRED for Read Aloud feature ────────
# Azure Portal → Speech Service → Keys and Endpoint
# Region: e.g. "eastus", "centralindia", "southeastasia"
AZURE_SPEECH_KEY=your-speech-service-key
AZURE_SPEECH_REGION=eastus

# ── Azure Translator  ← NO LONGER NEEDED ────────────────────────────────────
# Translation now uses GPT-4o/Groq for natural academic output.
# No separate Translator service key required.
